```gitignore
##############################
# Compiled class files
##############################
*.class

##############################
# Logs
##############################
*.log

##############################
# Package Files
##############################
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

##############################
# JVM crash logs
##############################
hs_err_pid*
replay_pid*

##############################
# IntelliJ IDEA
##############################
.idea/
*.iml
out/

##############################
# Eclipse
##############################
.project
.classpath
.settings/

##############################
# VS Code
##############################
.vscode/

##############################
# Maven
##############################
target/

##############################
# Gradle
##############################
.gradle/
build/

##############################
# OS Generated Files
##############################
.DS_Store
Thumbs.db

##############################
# Environment files
##############################
.env

##############################
# Temporary files
##############################
tmp/
temp/

##############################
# Generated documentation
##############################
site/

##############################
# Coverage reports
##############################
coverage/
jacoco.exec

##############################
# Serialization data
##############################
*.ser

##############################
# ExchangeX runtime data
##############################
data/
snapshots/
trades/
orders/
```
